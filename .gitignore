# =============================================================================
# KimBeggar — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECURITY — 절대 커밋 금지
# 아래 파일이 원격 저장소에 올라가면 API 키/토큰 탈취로 이어집니다.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# Kakao OAuth tokens (auto-generated by scripts/kakao_auth_setup.py)
data/kakao_token.json
data/*.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/

# Unit test / coverage
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.dmypy.json
.pytype/
.pyre/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Logs (auto-generated)
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
