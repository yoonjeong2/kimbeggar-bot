# ============================================================
# KimBeggar Bot — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual credentials.
#   cp .env.example .env          (Linux / macOS / Git Bash)
#   copy .env.example .env        (Windows CMD)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# NEVER commit .env to git — it is listed in .gitignore.
# ============================================================

# ------------------------------------------------------------
# KIS (한국투자증권) Open API
# ------------------------------------------------------------
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here

# 계좌번호 형식: 8자리-2자리  예) 12345678-01
KIS_ACCOUNT_NO=12345678-01
KIS_ACCOUNT_PRODUCT_CODE=01

# false = 모의투자 (테스트용 권장)
# true  = 실전투자 (실제 자금 — 주의!)
KIS_IS_REAL=false

# ------------------------------------------------------------
# Kakao Talk REST API
# ------------------------------------------------------------
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Kakao OAuth 토큰 저장 경로 (kakao_auth_setup.py 실행 시 자동 생성)
KAKAO_TOKEN_FILE=data/kakao_token.json

# ------------------------------------------------------------
# 모니터링 종목 (쉼표 구분, KRX 6자리 코드)
# ------------------------------------------------------------
# 005930 = 삼성전자
# 000660 = SK하이닉스
# 035420 = NAVER
WATCH_SYMBOLS=005930,000660,035420

# ------------------------------------------------------------
# 모니터링 주기
# ------------------------------------------------------------
MONITOR_INTERVAL_MINUTES=5

# ------------------------------------------------------------
# 전략 파라미터
# ------------------------------------------------------------
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MOVING_AVERAGE_SHORT=5
MOVING_AVERAGE_LONG=20

# 손절 기준: 0.05 = 진입가 대비 5% 하락 시 손절
STOP_LOSS_RATE=0.05

# 기본 헤지 비율: 0.30 = 포지션의 30%를 헤지
HEDGE_RATIO=0.30

# ------------------------------------------------------------
# 개발 모드 — SSL 인증서 우회 (Windows/macOS 로컬 환경)
# ------------------------------------------------------------
# SSLError: CERTIFICATE_VERIFY_FAILED 발생 시 DEV_MODE=true 설정
#
# 플랫폼별 근본 해결 방법:
#   Windows : pip install --upgrade certifi
#             또는 REQUESTS_CA_BUNDLE=C:\path\to\ca-bundle.crt 설정
#   macOS   : /Applications/Python 3.x/Install\ Certificates.command 실행
#   Linux   : sudo apt-get install ca-certificates   (Debian/Ubuntu)
#             sudo yum install ca-certificates        (RHEL/CentOS)
#
# 주의: DEV_MODE=true 는 TLS 검증을 완전히 비활성화합니다.
#       프로덕션 / CI 환경에서는 반드시 false 로 유지하세요.
DEV_MODE=false

# ------------------------------------------------------------
# 페이퍼 트레이딩 모드 (가상 체결 기록)
# ------------------------------------------------------------
# true  : 실제 주문 없이 data/bot_state.db의 paper_trades 테이블에 가상 체결 기록
#         전략 검증 / 성과 분석에 활용 (자금 위험 없음)
# false : 기본값 — 알림만 전송, paper_trades 테이블 미사용
PAPER_TRADING=false

# ------------------------------------------------------------
# Phase 6 — Alpaca API (미국 주식, 예정)
# ------------------------------------------------------------
# ALPACA_API_KEY_ID=your_alpaca_key_id
# ALPACA_API_SECRET_KEY=your_alpaca_secret_key
# ALPACA_PAPER=true          # true: Paper Trading 계정 / false: Live
# WATCH_SYMBOLS_US=AAPL,MSFT,SPY
